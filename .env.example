# ---- Production (required) ----
# Coinbase Developer Platform API key — authenticates the x402 facilitator
# that verifies and settles USDC payments on Base mainnet.
# Create at https://portal.cdp.coinbase.com -> API Keys.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ---- Production (optional) ----
# Discord webhook for payment notifications (channel settings -> Integrations -> Webhooks).
DISCORD_WEBHOOK_URL=
# Canonical public base URL used in openapi.json and MCP tool descriptions.
# Defaults to https://api.santosautomation.com.
PUBLIC_API_BASE_URL=

# ---- Durable free-tier rate limiting (optional; falls back to per-instance memory) ----
# Upstash Redis REST endpoint + token. With these set, the 1-free-audit/day
# limit survives cold starts and is shared across instances (atomic SET NX EX).
# Fails OPEN on store outage. IPs are HMAC-hashed with the secret before storage.
RATE_LIMIT_STORE_URL=
RATE_LIMIT_STORE_TOKEN=
RATE_LIMIT_HASH_SECRET=

# ---- MCP ----
# Extra allowed browser origins for the /mcp endpoint (comma-separated).
MCP_ALLOWED_ORIGINS=

# ---- Audit engine tuning (optional, sensible defaults) ----
AUDIT_TIMEOUT_MS=15000
MAX_REDIRECTS=5
MAX_RESPONSE_BYTES=5242880
MAX_URL_LENGTH=2048
ALLOWED_TARGET_PORTS=80,443

# ---- Local testing only — never set in deployed environments ----
# Throwaway buyer wallet for buy-audit.js / buy-live.js / npm test paid-flow checks.
BUYER_PRIVATE_KEY=

# ---- Deep Page Audit platform ----
# Feature flag: deep-tier routes return 503 until this is "true" AND storage is configured.
DEEP_AUDIT_ENABLED=false
DEEP_AUDIT_PRICE_USDC=0.075
# Postgres (e.g. Supabase) — jobs, queue, reports, artifacts. Control plane AND worker.
DATABASE_URL=
# Secrets for stateless auth (set BOTH in Vercel; REPORT_ACCESS_TOKEN_SECRET also unused by worker)
REPORT_ACCESS_TOKEN_SECRET=
IDEMPOTENCY_HASH_SECRET=

# ---- Worker (Fly.io) — set via `fly secrets set`, never in Vercel ----
# DATABASE_URL=            (same database)
# ANTHROPIC_API_KEY=       (optional: enables the ai-summary module)
# WORKER_JOB_TIMEOUT_SECONDS=300
# WORKER_MAX_ATTEMPTS=3
# BROWSER_NAVIGATION_TIMEOUT_MS=45000
# BROWSER_MAX_REQUESTS=400
# BROWSER_MAX_TOTAL_BYTES=41943040
# BROWSER_ALLOWED_PORTS=80,443
