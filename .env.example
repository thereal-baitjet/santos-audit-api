# ---- Production (required) ----
# Coinbase Developer Platform API key — authenticates the x402 facilitator
# that verifies and settles USDC payments on Base mainnet.
# Create at https://portal.cdp.coinbase.com -> API Keys.
CDP_API_KEY_ID=
CDP_API_KEY_SECRET=

# ---- Production (optional) ----
# Discord webhook for payment notifications (channel settings -> Integrations -> Webhooks).
DISCORD_WEBHOOK_URL=
# Canonical public base URL used in openapi.json and MCP tool descriptions.
# Defaults to https://api.santosautomation.com.
PUBLIC_API_BASE_URL=

# ---- Durable free-tier rate limiting (optional; falls back to per-instance memory) ----
# Upstash Redis REST endpoint + token. With these set, the 1-free-audit/day
# limit survives cold starts and is shared across instances (atomic SET NX EX).
# Fails OPEN on store outage. IPs are HMAC-hashed with the secret before storage.
RATE_LIMIT_STORE_URL=
RATE_LIMIT_STORE_TOKEN=
RATE_LIMIT_HASH_SECRET=

# ---- MCP ----
# Extra allowed browser origins for the /mcp endpoint (comma-separated).
MCP_ALLOWED_ORIGINS=

# ---- Agent Readiness ----
AGENT_READINESS_ENABLED=true
AGENT_READINESS_MAX_FETCHES=8
AGENT_READINESS_MAX_BYTES=1500000
AGENT_READINESS_TIMEOUT_MS=8000
AGENT_READINESS_MAX_DOC_LINKS=2
AGENT_READINESS_MAX_SITEMAP_URLS=25
AGENT_READINESS_DEEP_MAX_PAGES=3
AGENT_READINESS_CACHE_TTL_SECONDS=3600
# Active probes are still read-only: MCP initialize + tools/list only.
AGENT_READINESS_MCP_PROBE_ENABLED=false
# Optional preview registry lookup; disabled by default.
AGENT_READINESS_REGISTRY_LOOKUP_ENABLED=false
MCP_REGISTRY_BASE_URL=https://registry.modelcontextprotocol.io
# Paid by default at 0.025 USDC; override with another positive value (max 6 decimals).
AGENT_READINESS_PRICE_USDC=0.025
AGENT_READINESS_USER_AGENT=

# ---- Structured Extraction (POST /v1/extract/structured, Claude Sonnet 5) ----
# Anthropic API key for the MAIN VERCEL APP. Separate from the worker's own
# ANTHROPIC_API_KEY below (Fly.io) — this product runs as a Vercel serverless
# function and does not inherit the worker's key or its @anthropic-ai/sdk dep.
ANTHROPIC_API_KEY=
# Paid by default at 0.08 USDC; override with another positive value (max 6 decimals).
STRUCTURED_EXTRACT_PRICE_USDC=0.08

# ---- Audit engine tuning (optional, sensible defaults) ----
AUDIT_TIMEOUT_MS=15000
MAX_REDIRECTS=5
MAX_RESPONSE_BYTES=5242880
MAX_URL_LENGTH=2048
ALLOWED_TARGET_PORTS=80,443

# ---- Local testing only — never set in deployed environments ----
# Throwaway buyer wallet for buy-audit.js / buy-live.js / npm test paid-flow checks.
BUYER_PRIVATE_KEY=

# ---- Deep Page Audit platform ----
# Feature flag: deep-tier routes return 503 until this is "true" AND storage is configured.
DEEP_AUDIT_ENABLED=false
DEEP_AUDIT_PRICE_USDC=0.075
# Postgres (e.g. Supabase) — jobs, queue, reports, artifacts. Control plane AND worker.
DATABASE_URL=
# Secrets for stateless auth (set BOTH in Vercel; REPORT_ACCESS_TOKEN_SECRET also unused by worker)
REPORT_ACCESS_TOKEN_SECRET=
IDEMPOTENCY_HASH_SECRET=

# ---- Worker (Fly.io) — set via `fly secrets set`, never in Vercel ----
# DATABASE_URL=            (same database)
# ANTHROPIC_API_KEY=       (optional: enables the ai-summary module)
# WORKER_JOB_TIMEOUT_SECONDS=300
# WORKER_MAX_ATTEMPTS=3
# BROWSER_NAVIGATION_TIMEOUT_MS=45000
# BROWSER_MAX_REQUESTS=400
# BROWSER_MAX_TOTAL_BYTES=41943040
# BROWSER_ALLOWED_PORTS=80,443

# ---- Stripe (human $5 Agent Readiness Report) ----
# From the Stripe dashboard. STRIPE_PRICE_ID is optional (inline price used if unset).
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=
# ---- Email (Resend) — report delivery ----
# Verify santosautomation.com in Resend to send from reports@santosautomation.com;
# otherwise set RESEND_SENDER=onboarding@resend.dev as a fallback.
RESEND_API_KEY=
RESEND_SENDER=
# Canonical site origin for report links / redirects (defaults to www.santosautomation.com)
PUBLIC_SITE_URL=
